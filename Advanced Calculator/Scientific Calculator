import java.util.*;

class ScientificCalculator {

    
    double add(double a, double b) { return a + b; }
    double sub(double a, double b) { return a - b; }
    double mul(double a, double b) { return a * b; }

    double div(double a, double b) {
        if (b == 0) throw new ArithmeticException("Divide by zero!");
        return a / b;
    }

    double power(double a, double b) { return Math.pow(a, b); }
    double sqrt(double a) {
        if (a < 0) throw new ArithmeticException("Negative input!");
        return Math.sqrt(a);
    }

    double mod(double a, double b) { return a % b; }

    double sin(double a) { return Math.sin(Math.toRadians(a)); }
    double cos(double a) { return Math.cos(Math.toRadians(a)); }
    double tan(double a) { return Math.tan(Math.toRadians(a)); }

    double log(double a) {
        if (a <= 0) throw new ArithmeticException("Invalid input for log!");
        return Math.log10(a);
    }

    double ln(double a) {
        if (a <= 0) throw new ArithmeticException("Invalid input for ln!");
        return Math.log(a);
    }

    long factorial(int n) {
        if (n < 0) throw new ArithmeticException("Negative factorial!");
        long fact = 1;
        for (int i = 1; i <= n; i++) fact *= i;
        return fact;
    }
}

