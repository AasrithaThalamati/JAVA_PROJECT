import java.util.*;

class Question {
    String question;
    String[] options;
    int correctAnswer;
    String difficulty;

    public Question(String question, String[] options, int correctAnswer, String difficulty) {
        this.question = question;
        this.options = options;
        this.correctAnswer = correctAnswer;
        this.difficulty = difficulty;
    }

    public boolean askQuestion(Scanner sc) {
        System.out.println("\n[" + difficulty + "] " + question);

        for (int i = 0; i < options.length; i++) {
            System.out.println((i + 1) + ". " + options[i]);
        }

        int userAnswer = 0;

        while (true) {
            System.out.print("Enter your answer (1-4): ");
            if (sc.hasNextInt()) {
                userAnswer = sc.nextInt();
                if (userAnswer >= 1 && userAnswer <= 4) break;
            } else {
                sc.next(); // clear invalid input
            }
            System.out.println("Invalid input! Try again.");
        }

        if (userAnswer == correctAnswer) {
            System.out.println("✅ Correct!");
            return true;
        } else {
            System.out.println("❌ Wrong! Correct answer: " + options[correctAnswer - 1]);
            return false;
        }
    }
}

public class AdvancedQuizApp {

    static List<Question> getQuestions() {
        List<Question> quiz = new ArrayList<>();

        quiz.add(new Question(
                "What is the capital of India?",
                new String[]{"Mumbai", "Delhi", "Chennai", "Kolkata"},
                2, "Easy"));

        quiz.add(new Question(
                "Which keyword is used to inherit a class in Java?",
                new String[]{"this", "super", "extends", "implements"},
                3, "Medium"));

        quiz.add(new Question(
                "Time complexity of binary search?",
                new String[]{"O(n)", "O(log n)", "O(n log n)", "O(1)"},
                2, "Medium"));

        quiz.add(new Question(
                "Which company developed Java?",
                new String[]{"Google", "Sun Microsystems", "IBM", "Apple"},
                2, "Easy"));

        quiz.add(new Question(
                "Which data structure uses FIFO?",
                new String[]{"Stack", "Queue", "Tree", "Graph"},
                2, "Easy"));

        return quiz;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        do {
            List<Question> quiz = getQuestions();
            Collections.shuffle(quiz); // random order

            int score = 0;

            System.out.println("\n=== 🎯 Welcome to Advanced Quiz ===");

            for (Question q : quiz) {

                long startTime = System.currentTimeMillis();

                boolean correct = q.askQuestion(sc);

                long endTime = System.currentTimeMillis();
                long timeTaken = (endTime - startTime) / 1000;

                if (timeTaken > 10) {
                    System.out.println("⏰ Time exceeded! No points awarded.");
                } else if (correct) {
                    score++;
                }
            }

            double percentage = (score * 100.0) / quiz.size();

            System.out.println("\n=== 📊 Results ===");
            System.out.println("Score: " + score + "/" + quiz.size());
            System.out.println("Percentage: " + percentage + "%");

            if (percentage >= 80)
                System.out.println("🌟 Excellent!");
            else if (percentage >= 50)
                System.out.println("👍 Good Job!");
            else
                System.out.println("📘 Keep Practicing!");

            System.out.print("\nDo you want to play again? (yes/no): ");
            sc.nextLine(); // clear buffer
        } while (sc.nextLine().equalsIgnoreCase("yes"));

        sc.close();
    }
}
